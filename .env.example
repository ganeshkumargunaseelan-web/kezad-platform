# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:admin@postgres:5432/kezad

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-in-production-access-secret-min-64-chars
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-min-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Integration Adapters (mock | real) ──────────────────────────────────────
CRM_ADAPTER=mock
ERP_ADAPTER=mock
SCADA_ADAPTER=mock
BMS_ADAPTER=mock
REGULATORY_ADAPTER=mock
PAYMENT_ADAPTER=mock
NOTIFICATION_ADAPTER=mock

# ─── Real CRM (Dynamics 365) — only needed when CRM_ADAPTER=dynamics365 ──────
D365_TENANT_ID=
D365_CLIENT_ID=
D365_CLIENT_SECRET=
D365_ENVIRONMENT_URL=

# ─── Real ERP (Oracle Fusion) — only needed when ERP_ADAPTER=oracle_fusion ───
ORACLE_BASE_URL=
ORACLE_USERNAME=
ORACLE_PASSWORD=

# ─── Real SCADA (OPC UA) — only needed when SCADA_ADAPTER=opcua ──────────────
OPCUA_SIEMENS_ENDPOINT=opc.tcp://siemens-wincc:4840
OPCUA_EMERSON_ENDPOINT=opc.tcp://emerson-oe:4840

# ─── Real BMS (Modbus) — only needed when BMS_ADAPTER=modbus ─────────────────
MODBUS_TRIDIUM_HOST=
MODBUS_TRIDIUM_PORT=502
MODBUS_HONEYWELL_HOST=
MODBUS_HONEYWELL_PORT=502

# ─── Real Notifications — only needed when NOTIFICATION_ADAPTER=smtp|twilio ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kezad.ae
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Real Payment Gateway ─────────────────────────────────────────────────────
PAYMENT_GATEWAY_URL=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET=

# ─── Regulatory (ATLP/Maqta) ─────────────────────────────────────────────────
ATLP_BASE_URL=
ATLP_API_KEY=
ATLP_CLIENT_ID=

# ─── Frontends ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
CUSTOMER_PORTAL_PORT=3000
EMPLOYEE_PORTAL_PORT=3002
