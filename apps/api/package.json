    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@kezad/database": "*",
    "@kezad/types": "*",
    "@kezad/utils": "*",
    "@paralleldrive/cuid2": "^2.2.2",
    "bcrypt": "^5.1.1",
    "decimal.js": "^10.4.3",
